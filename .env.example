# Docker / Ports (opcional)
# Use quando alguma porta do host já estiver ocupada.
# Ex:
#   DB_HOST_PORT=5434
#   BACKEND_HOST_PORT=3002
#   FRONTEND_HOST_PORT=5174
DB_HOST_PORT=
BACKEND_HOST_PORT=
FRONTEND_HOST_PORT=

# Backend / Meta Graph (opcional)
# - Se META_SYNC_PROVIDER=meta e não houver token válido, o sync falhará.
# - Se META_SYNC_PROVIDER=stub, sempre usa provider stub (mesmo com token).
META_SYNC_PROVIDER=
META_GRAPH_VERSION=v20.0
META_ACCESS_TOKEN=

# Creative REAL (opcional)
# - O publish de AdCreative exige `pageId` (UI ou env). Instagram Actor ID é opcional.
META_PAGE_ID=
META_INSTAGRAM_ACTOR_ID=
